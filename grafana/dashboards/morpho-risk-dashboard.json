{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Vault Health Factor (5m avg)",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT bucket AS \"time\", avg_health_factor AS value, vault_id AS metric FROM hf_5m WHERE $__timeFilter(bucket) ORDER BY bucket",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 1.05},
              {"color": "yellow", "value": 1.2},
              {"color": "green", "value": 1.5}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Latest Anomaly Events",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 9},
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT ts, vault_id, severity, observed_health_factor, expected_health_factor, robust_z_score, risk_score FROM anomaly_events WHERE $__timeFilter(ts) ORDER BY ts DESC LIMIT 100",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Critical Events (24h)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 18},
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT NOW() AS \"time\", COUNT(*) AS value FROM anomaly_events WHERE ts >= NOW() - INTERVAL '24 hours' AND severity = 'critical'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Warning Events (24h)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 18},
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT NOW() AS \"time\", COUNT(*) AS value FROM anomaly_events WHERE ts >= NOW() - INTERVAL '24 hours' AND severity = 'warning'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tracked Vaults",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 18},
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT NOW() AS \"time\", COUNT(DISTINCT vault_id) AS value FROM vault_health_metrics WHERE ts >= NOW() - INTERVAL '1 day'",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["morpho", "risk", "anomaly"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Morpho Vault Risk Monitoring",
  "uid": "morpho-vault-risk",
  "version": 1
}