{
  "uid": "defi-vault-risk",
  "title": "DeFi Vault Risk Monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-7d", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "vault",
        "type": "query",
        "datasource": {"type": "postgres", "uid": "timescaledb_uid"},
        "query": "SELECT DISTINCT vault_slug FROM defi_vault_metrics ORDER BY 1",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {"selected": true, "text": "All", "value": ".*"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "TVL per Vault",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 9},
      "datasource": {"type": "postgres", "uid": "timescaledb_uid"},
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time AS \"time\", tvl_usd AS value, vault_slug AS metric FROM defi_vault_metrics WHERE $__timeFilter(time) AND vault_slug ~ '${vault:regex}' ORDER BY 1"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Current Risk Score",
      "gridPos": {"x": 0, "y": 9, "w": 8, "h": 7},
      "datasource": {"type": "postgres", "uid": "timescaledb_uid"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT MAX(risk_score) AS risk_score FROM latest_metrics WHERE vault_slug ~ '${vault:regex}'"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.15},
              {"color": "red", "value": 0.35}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Top 10 Vaults by Risk Score",
      "gridPos": {"x": 8, "y": 9, "w": 16, "h": 7},
      "datasource": {"type": "postgres", "uid": "timescaledb_uid"},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT vault_slug, current_risk_score, avg_var_95_24h, avg_volatility_24h, latest_time FROM top_risky_vaults ORDER BY current_risk_score DESC LIMIT 10"
        }
      ]
    }
  ]
}